# ── News / Media ──────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_ai_key_here
NEWS_API_URL=https://eventregistry.org/api/v1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# ── Redis (vector store) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost
REDIS_PORT=6379

# ── X (Twitter) API v2 ────────────────────────────────────────────────────────
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── OGD Platform India (FIR data) ─────────────────────────────────────────────
OGD_API_KEY=your_ogd_api_key_here
# Resource ID for the FIR / crime dataset on api.data.gov.in
OGD_FIR_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

# ── Legislative Data Sources ──────────────────────────────────────────────────
PRS_BASE_URL=https://api.prsindia.org/api
DIGITAL_SANSAD_URL=https://sansad.in/ls
ADR_BASE_URL=https://myneta.info/api

# ── Fact-Checking ─────────────────────────────────────────────────────────────
ORIGINALITY_API_KEY=your_originality_api_key_here

# ── Posting Limits ────────────────────────────────────────────────────────────
MAX_POSTS_PER_DAY=10
POST_INTERVAL_MINUTES=60

# ── Human-in-the-Loop ─────────────────────────────────────────────────────────
# Set to False to enable fully automated posting (not recommended)
HITL_ENABLED=True

# ── AI Labeling (IT Rules 2026 / SGI compliance) ──────────────────────────────
AI_LABEL_PREFIX=[AI-Generated]
